{
  "version": 2,
  "builds": [
    { "src": "index.html", "use": "@vercel/static" },
    { "src": "style.css", "use": "@vercel/static" },
    { "src": "script.js", "use": "@vercel/static" },
    { "src": "s4-Picsart-AiImageEnhancer-removebg-preview.png", "use": "@vercel/static" },
    { "src": "s1.jpg", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/style.css", "dest": "/style.css" },
    { "src": "/script.js", "dest": "/script.js" },
    { "src": "/s4-Picsart-AiImageEnhancer-removebg-preview.png", "dest": "/s4-Picsart-AiImageEnhancer-removebg-preview.png" },
    { "src": "/s1.jpg", "dest": "/s1.jpg" },
    { "src": "/", "dest": "/index.html" },
    { "src": "/(.*)", "dest": "/index.html" }
  ]
}
